#!/usr/bin/env python3
"""
Preview-only AI enrichment for symbols imported by easyeda2kicad.

Looks up an LCSC part on lcsc.com via `claude -p` (WebFetch), proposes a
better Description if the current one is weak/empty, and shows a unified
diff. By default writes nothing — pass --apply to actually patch the
library file. Other weak fields are surfaced as warnings with a copy-paste
follow-up command, not auto-changed.

Usage:
  lcsc-enrich C2453576              # preview only (default)
  lcsc-enrich C2453576 --apply      # apply the description change shown
  lcsc-enrich C2453576 --set ki_keywords "buck converter 3A"
"""
from __future__ import annotations

import argparse
import difflib
import json
import os
import re
import subprocess
import sys
from pathlib import Path

KICAD9_3RD_PARTY = Path(
    os.environ.get("KICAD9_3RD_PARTY", "/Users/brendan/Documents/KiCad/9.0/3rdparty")
)
LIBRARY = KICAD9_3RD_PARTY / "libraries" / "easyeda.kicad_sym"

EVALUATED_FIELDS = ("Description", "ki_keywords", "Value")
CONTEXT_FIELDS = ("MPN", "Manufacturer", "Footprint", "Datasheet")


def _property_re(name: str) -> re.Pattern[str]:
    # Tolerates the two formatting styles easyeda2kicad emits:
    #   (property "Name" "Value" ...)            single-line
    #   (property\n  "Name"\n  "Value"\n ...)    multi-line
    return re.compile(rf'\(property\s+"{re.escape(name)}"\s+"([^"]*)"')


def find_symbol_block(text: str, lcsc_id: str) -> tuple[int, int] | None:
    """Locate the (symbol …) block whose 'LCSC Part' property == lcsc_id."""
    symbol_re = re.compile(r'^[ \t]+\(symbol "[^"]*"', re.MULTILINE)
    lcsc_part_re = _property_re("LCSC Part")
    for m in symbol_re.finditer(text):
        start = m.start()
        depth = 0
        i = start
        n = len(text)
        while i < n:
            c = text[i]
            if c == '"':
                i += 1
                while i < n and text[i] != '"':
                    if text[i] == '\\':
                        i += 1
                    i += 1
            elif c == '(':
                depth += 1
            elif c == ')':
                depth -= 1
                if depth == 0:
                    end = i + 1
                    block = text[start:end]
                    pm = lcsc_part_re.search(block)
                    if pm and pm.group(1) == lcsc_id:
                        return start, end
                    break
            i += 1
    return None


def get_property(block: str, name: str) -> str | None:
    m = _property_re(name).search(block)
    return m.group(1) if m else None


def set_property(block: str, name: str, value: str) -> str | None:
    """Replace value of an existing property. Returns None if not present."""
    pattern = rf'(\(property\s+"{re.escape(name)}"\s+")([^"]*)(")'
    m = re.search(pattern, block)
    if not m:
        return None
    return block[: m.start(2)] + value + block[m.end(2) :]


def add_or_set_property(block: str, name: str, value: str) -> str | None:
    """Replace value if property exists, else insert a new property line.

    Insertion point: just before the inner geometry sub-symbol (the
    `(symbol "<MPN>_<n>_<n>" …)` block that holds pins and shapes), with
    indentation matched to the first existing property in the block.
    """
    replaced = set_property(block, name, value)
    if replaced is not None:
        return replaced

    inner = re.search(r'^([ \t]+)\(symbol "[^"]+_\d+_\d+"', block, re.MULTILINE)
    if not inner:
        return None
    indent = inner.group(1)
    line = (
        f'{indent}(property "{name}" "{value}" '
        f'(at 0 0 0) (effects (font (size 1.27 1.27)) (hide yes)))\n'
    )
    return block[: inner.start()] + line + block[inner.start() :]


def call_claude(lcsc_id: str, current: dict[str, str]) -> dict:
    prompt = f"""You are cleaning up a KiCad symbol's "Description" using ONLY the data below. Do not look anything up on the web. Do not invent specs that aren't derivable from these inputs.

You MAY:
- Restate the provided facts in clearer English.
- Decode unambiguous MPN value codes (e.g. "6R8" -> 6.8, "100" -> 10x10^0) when the family is obvious from the manufacturer + MPN prefix and the encoding is industry-standard.
- Read body dimensions out of the footprint name verbatim — that string is the source of truth for size (e.g. "_L5.4-W5.2" means a 5.4 x 5.2 mm body).

You MUST NOT:
- Add tolerance, voltage, current, temperature, or pin-count specs unless they appear in the inputs below or are unambiguously encoded in the MPN.
- Override the body size implied by the footprint name with anything else.
- Output anything that is just a guess. When uncertain, omit the spec.

Inputs (LCSC part {lcsc_id}):
- Manufacturer:      {current.get('Manufacturer', '')!r}
- MPN:               {current.get('MPN', '')!r}
- Value (current):   {current.get('Value', '')!r}
- ki_keywords:       {current.get('ki_keywords', '')!r}
- Footprint name:    {current.get('Footprint', '')!r}
- Datasheet (URL):   {current.get('Datasheet', '')!r}    (do NOT fetch — provided as context only)
- Description (current): {current.get('Description', '')!r}

Respond with ONLY a JSON object — no prose, no code fences:

{{
  "description":  {{"current_quality": "weak|ok|good", "suggested": "<one line, <=80 chars>"}},
  "ki_keywords":  {{"current_quality": "weak|ok|good", "suggested": "<2-5 short tokens>"}},
  "value":        {{"current_quality": "weak|ok|good", "suggested": "<canonical MPN, usually unchanged>"}}
}}

Quality:
- weak: empty, just an ID/SKU, or so generic it's useless ("Resistors", "Power Inductors")
- ok:   identifies family but is missing specs that the inputs make available
- good: enough detail an engineer recognizes the part at a glance

Suggested description shape: "<Manufacturer> <MPN> — <decoded specs if any> <kind>, <body size from footprint>"
"""
    try:
        result = subprocess.run(
            ["claude", "-p", prompt],
            capture_output=True,
            text=True,
            timeout=180,
            check=True,
        )
    except FileNotFoundError:
        sys.exit("lcsc-enrich: `claude` CLI not found on PATH")
    except subprocess.CalledProcessError as e:
        sys.exit(f"lcsc-enrich: claude failed (exit {e.returncode})\n{e.stderr}")
    except subprocess.TimeoutExpired:
        sys.exit("lcsc-enrich: claude timed out after 180s")

    out = result.stdout.strip()
    out = re.sub(r"^```(?:json)?\s*|\s*```\s*$", "", out, flags=re.MULTILINE)
    first = out.find("{")
    last = out.rfind("}")
    if first < 0 or last < 0:
        sys.exit(f"lcsc-enrich: no JSON object in claude output:\n{out}")
    try:
        return json.loads(out[first : last + 1])
    except json.JSONDecodeError as e:
        sys.exit(f"lcsc-enrich: invalid JSON from claude: {e}\n{out[first:last+1]}")


def colored_diff(block: str, proposed: str, lcsc_id: str) -> None:
    use_color = sys.stdout.isatty()
    diff = difflib.unified_diff(
        block.splitlines(keepends=True),
        proposed.splitlines(keepends=True),
        fromfile=f"{lcsc_id} (current)",
        tofile=f"{lcsc_id} (proposed)",
    )
    for line in diff:
        if not use_color:
            sys.stdout.write(line)
            continue
        if line.startswith("+++") or line.startswith("---"):
            sys.stdout.write(f"\033[1m{line}\033[0m")
        elif line.startswith("+"):
            sys.stdout.write(f"\033[32m{line}\033[0m")
        elif line.startswith("-"):
            sys.stdout.write(f"\033[31m{line}\033[0m")
        elif line.startswith("@@"):
            sys.stdout.write(f"\033[36m{line}\033[0m")
        else:
            sys.stdout.write(line)


def write_block(text: str, start: int, end: int, new_block: str) -> None:
    LIBRARY.write_text(text[:start] + new_block + text[end:])


def main() -> None:
    ap = argparse.ArgumentParser(description=__doc__.strip().splitlines()[0])
    ap.add_argument("lcsc_id", help="LCSC part id, e.g. C2453576")
    ap.add_argument(
        "--apply",
        action="store_true",
        help="write the proposed Description change (default: preview only)",
    )
    ap.add_argument(
        "--set",
        nargs=2,
        metavar=("FIELD", "VALUE"),
        help="set a single property by hand and exit (no AI lookup)",
    )
    args = ap.parse_args()

    if not LIBRARY.exists():
        sys.exit(f"lcsc-enrich: library not found at {LIBRARY}")
    text = LIBRARY.read_text()
    found = find_symbol_block(text, args.lcsc_id)
    if not found:
        sys.exit(f"lcsc-enrich: no symbol with 'LCSC Part' = {args.lcsc_id} in {LIBRARY}")
    start, end = found
    block = text[start:end]

    if args.set:
        field, value = args.set
        new_block = add_or_set_property(block, field, value)
        if new_block is None:
            sys.exit(f"lcsc-enrich: could not place property {field!r} in symbol")
        write_block(text, start, end, new_block)
        print(f"✓ Set {field} = {value!r}")
        return

    raw = {f: get_property(block, f) for f in EVALUATED_FIELDS + CONTEXT_FIELDS}
    current = {f: (raw[f] or "") for f in raw}
    desc_missing = raw["Description"] is None

    print(f"Reformatting {args.lcsc_id} fields via Claude (no web lookup)...", file=sys.stderr)
    sug = call_claude(args.lcsc_id, current)

    proposed_block = block
    desc = sug.get("description") or {}
    # Missing Description is at least as bad as weak — treat as weak.
    desc_quality = "weak" if desc_missing else desc.get("current_quality")
    desc_suggested = (desc.get("suggested") or "").strip()
    will_change_desc = (
        desc_quality == "weak"
        and desc_suggested
        and desc_suggested != current["Description"]
    )
    if will_change_desc:
        nb = add_or_set_property(proposed_block, "Description", desc_suggested)
        if nb is not None:
            proposed_block = nb

    if proposed_block != block:
        colored_diff(block, proposed_block, args.lcsc_id)
        if args.apply:
            write_block(text, start, end, proposed_block)
            print(f"\n✓ Applied to {LIBRARY}")
        else:
            print(f"\n(preview only — re-run with --apply to write)")
    else:
        print(
            f"No description change proposed "
            f"(current quality: {desc_quality or '?'}, current: {current['Description']!r})"
        )

    # Warnings for the other evaluated fields
    warning_map = (("ki_keywords", "ki_keywords"), ("Value", "value"))
    warnings_emitted = False
    for field, key in warning_map:
        s = sug.get(key) or {}
        suggested = (s.get("suggested") or "").strip()
        if (
            s.get("current_quality") == "weak"
            and suggested
            and suggested != current.get(field, "")
        ):
            if not warnings_emitted:
                print()  # blank line before warnings
                warnings_emitted = True
            print(f"⚠️  {field} looks weak: {current.get(field, '')!r}")
            print(f"   Suggested: {suggested!r}")
            print(
                f"   To apply:  lcsc-enrich {args.lcsc_id} --set {field} "
                f"{json.dumps(suggested)}"
            )


if __name__ == "__main__":
    main()
